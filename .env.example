# LinkedIn credentials
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# LLM — Gemini uniquement, pas d'Ollama
# Obtenez votre clé sur https://aistudio.google.com/apikey
GEMINI_API_KEY=
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
# Fallback model used when primary hits daily quota (Free-Tier quotas are distinct per model)
GEMINI_FALLBACK_MODEL=gemini-1.5-flash
# Delay in seconds between LLM scoring calls (reduces per-minute rate-limit pressure)
GEMINI_INTER_CALL_DELAY_S=2

# Storage
DB_PATH=./data/linkedin.db
SESSION_PATH=./data/session.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# Behaviour
DRY_RUN=false
MAX_INVITATIONS_PER_DAY=15
MAX_ACTIONS_PER_DAY=500
# Activity window timezone — uses Python zoneinfo (stdlib, no extra deps)
# Must be a valid IANA timezone name (e.g. Europe/Paris, America/New_York)
ACTIVITY_TIMEZONE=Europe/Paris
